# --- Core (required) ---
BOT_TOKEN=123456:REPLACE_ME
JWT_SECRET=replace-with-64-char-random-hex
DATA_ENC_KEY=replace-with-64-hex-chars-32-bytes
DATABASE_PATH=./data/stasis.sqlite
PORT=3000

# --- Bot / webhook (optional in dev; required together in prod) ---
# The Mini App URL opened by the /start web_app button.
MINIAPP_URL=https://your-miniapp.example
# Public HTTPS origin of THIS server (used to register the Telegram webhook).
PUBLIC_BASE_URL=https://api.your-domain.example
# Secret verifying inbound Telegram webhook updates. REQUIRED when PUBLIC_BASE_URL is set
# (the server refuses to boot otherwise) — without it, forged updates could invoke /delete_my_data.
WEBHOOK_SECRET=replace-with-random-secret
# Telegram deep-link base for viral share links, e.g. https://t.me/<bot> (or https://t.me/<bot>/<app>).
# DISTINCT from PUBLIC_BASE_URL — this must point at the bot/app in Telegram, not the API server.
TG_SHARE_BASE_URL=https://t.me/your_bot

# --- Mini App build-time (apps/miniapp) ---
# VITE_API_BASE=https://api.your-domain.example
# VITE_POLICY_URL=https://your-domain.example/policy
# VITE_OFFER_URL=https://your-domain.example/offer
